# LLM: ollama | perplexity
LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Perplexity API (berbayar terpisah dari Max — set di https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Sandbox
WORKSPACE=./workspace
SANDBOX_IMAGE=debian:12-slim
# docker network: bridge | none (none memutus internet di dalam kontainer)
SANDBOX_NETWORK=bridge
